NEXT_PUBLIC_APP_URL=http://localhost:3000

# JWT secret – must be at least 32 random characters
AUTH_SECRET=

# Initial admin credentials (used by the seed script)
ADMIN_INITIAL_EMAIL=
ADMIN_INITIAL_PASSWORD=

# Upstash Redis (get these from console.upstash.com)
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

HEALTH_APP_REDIS_PREFIX=bht:v1:

# Private bearer token for the reminder processing endpoint (minimum 32 characters)
REMINDER_PROCESSOR_SECRET=
